{
  "name": "@aristath/soulswitch",
  "version": "0.1.0",
  "description": "SoulSwitch core agent orchestration library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:live": "node --env-file=.env.e2e.local ./node_modules/vitest/vitest.mjs run src/proxy/live.e2e.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "agents",
    "llm",
    "tools",
    "plugins"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "zod": "^3.24.2"
  }
}
